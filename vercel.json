{
  "rewrites": [
    {
      "source": "/jio1/(.*)",
      "destination": "https://saavn.me/$1"
    },
    {
      "source": "/jio2/(.*)",
      "destination": "https://jiosaavn-api-2.vercel.app/$1"
    },
    {
      "source": "/jio3/(.*)",
      "destination": "https://jiosaavn-api-beta-one.vercel.app/$1"
    },
    {
      "source": "/jio4/(.*)",
      "destination": "https://jioapi-v3.vercel.app/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
